generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String  @id
  name        String
  description String
  price       Float
  image       String
  category    String
  intensity   Int
  origin      String
  weight      String
  region      String?
}
